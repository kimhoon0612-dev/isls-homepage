// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String
  affiliation   String?
  role          String    @default("USER") // USER, PAID_USER, ADMIN
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  payments      Payment[]
}

model Notice {
  id          String   @id @default(cuid())
  title       String
  content     String
  isImportant Boolean  @default(false)
  viewCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Payment {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  eximbayTxId   String?  @unique
  amount        Int
  currency      String   @default("USD")
  type          String   // MEMBERSHIP, DONATION
  status        String   // PENDING, COMPLETED, FAILED
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Vod {
  id          String   @id @default(cuid())
  title       String
  description String?
  videoUrl    String
  thumbnailUrl String?
  isRestricted Boolean @default(true) // Requires PAID_USER role
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
